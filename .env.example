# ─── ATS Resume Checker — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values

# Google Gemini API Key (FREE — get yours at https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Max file upload size in MB (default handled client-side)
# VITE_MAX_FILE_SIZE_MB=5
